{
  "name": "@kastalien-research/effect-airtable-mcp",
  "version": "0.3.0",
  "description": "Effect-based Airtable Model Context Protocol Server",
  "type": "module",
  "bin": {
    "airtable-server": "build/index.js"
  },
  "files": [
    "build",
    "scripts",
    "src/docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/post-build.js",
    "prepare": "husky",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.28.0",
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/coverage-v8": "^3.1.4",
    "@vitest/ui": "^3.1.4",
    "c8": "^10.1.3",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  },
  "author": "glassBead",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glassBead-tc/effect-airtable-mcp"
  },
  "keywords": [
    "airtable",
    "mcp",
    "model-context-protocol",
    "claude",
    "api",
    "effect",
    "effect-ts",
    "typescript",
    "zod",
    "type-safe",
    "validation",
    "schema"
  ],
  "homepage": "https://github.com/glassBead-tc/effect-airtable-mcp#readme",
  "bugs": {
    "url": "https://github.com/glassBead-tc/effect-airtable-mcp/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
